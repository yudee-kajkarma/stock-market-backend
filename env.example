# Environment Configuration
NODE_ENV=development
PORT=3001

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Upstox API Configuration (Optional - now stored in database)
# This is only needed if you want to set a fallback token
UPSTOX_ACCESS_TOKEN=your_upstox_access_token

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Make sure to run the SQL script to create the access_tokens table
# 4. Insert your access token into the database using the API endpoint or SQL
